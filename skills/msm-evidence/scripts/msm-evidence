#!/usr/bin/env bash
# msm-evidence — CLI entrypoint for the msm-evidence skill.
# Usage: msm-evidence <command> [options]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PY="${PYTHON:-python3}"

sub="${1:-}"
shift || true

case "$sub" in
  collect)
    exec "$PY" "$SCRIPT_DIR/collect.py" "$@"
    ;;
  verify)
    exec "$PY" "$SCRIPT_DIR/verify.py" "$@"
    ;;
  list)
    exec "$PY" "$SCRIPT_DIR/list_seeds.py" "$@"
    ;;
  ""|-h|--help)
    cat <<EOF
msm-evidence — Evidence Collector for MSM v1.0.0

Commands:
  collect   Fetch + chunk + dedup + write seeds
  verify    Validate seeds.jsonl integrity
  list      List collected seeds

Common options:
  --target PATH       KB root (default: .)

collect options:
  --source URI [...]  One or more URIs (URL or file path)
  --sources-file PATH File containing URIs, one per line
  --chunk-size INT    Max chunk size in chars (default: 1200)
  --chunk-overlap INT Overlap between chunks (default: 100)
  --cluster NAME      Ontology cluster hint (stored as metadata)
  --apply             Actually write files (default: dry-run)
  --dry-run           Plan only, no writes (default)
  --max-retry INT     HTTP retry limit (default: 1)
  --user-agent STR    HTTP User-Agent (default: msm-evidence/1.0)
  --run-id STR        Trajectory run identifier

verify options:
  --id SEED_ID        Verify a specific seed

list options:
  --format table|json|ids   Output format (default: table)
EOF
    ;;
  *)
    echo "unknown subcommand: $sub" >&2
    echo "Use 'msm-evidence --help' for usage." >&2
    exit 2
    ;;
esac
