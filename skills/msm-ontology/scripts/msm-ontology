#!/usr/bin/env bash
# msm-ontology — CLI entrypoint for the msm-ontology skill.
# Usage: msm-ontology <command> [options]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# 스킬 venv를 우선 사용 (pyshacl, rdflib 등 격리 설치)
if [[ -x "$SKILL_DIR/.venv/bin/python3" ]]; then
  PY="${PYTHON:-$SKILL_DIR/.venv/bin/python3}"
else
  PY="${PYTHON:-python3}"
fi

sub="${1:-}"
shift || true

case "$sub" in
  add)
    exec "$PY" "$SCRIPT_DIR/add.py" "$@"
    ;;
  mece)
    exec "$PY" "$SCRIPT_DIR/mece.py" "$@"
    ;;
  list)
    exec "$PY" "$SCRIPT_DIR/list.py" "$@"
    ;;
  project)
    exec "$PY" "$SCRIPT_DIR/project_md.py" "$@"
    ;;
  definition)
    exec "$PY" "$SCRIPT_DIR/definition.py" "$@"
    ;;
  shapes-validate)
    exec "$PY" "$SCRIPT_DIR/shapes_validate.py" "$@"
    ;;
  eca-run)
    exec "$PY" "$SCRIPT_DIR/eca_run.py" "$@"
    ;;
  eca-schedule)
    exec "$PY" "$SCRIPT_DIR/eca_schedule.py" "$@"
    ;;
  gen-ddl)
    exec "$PY" "$SCRIPT_DIR/gen_ddl.py" "$@"
    ;;
  compile)
    exec "$PY" "$SCRIPT_DIR/compile.py" "$@"
    ;;
  reason)
    exec "$PY" "$SCRIPT_DIR/reason.py" "$@"
    ;;
  materialize)
    exec "$PY" "$SCRIPT_DIR/materialize.py" "$@"
    ;;
  explain)
    exec "$PY" "$SCRIPT_DIR/explain.py" "$@"
    ;;
  ""|-h|--help)
    cat <<EOF
msm-ontology — Ontology Manager for MSM v0.13.0

Commands (v0.12.0):
  add                Register entity / relation / instance
  mece               Run MECE violation checks
  list               List registered objects
  project            Regenerate MD projections from JSONL
  definition         Load / query definition YAML
  shapes-validate    SHACL 기반 Tbox 검증 (v0.14.0 — pyshacl)
  eca-run            Execute ECA rules on a table row
  eca-schedule       Schedule ECA rules for a domain
  gen-ddl            Generate SQL DDL from definition

Commands (v0.13.0 — OWL reasoning):
  compile            LinkML YAML → OWL/Turtle  (requires: pip install linkml)
  reason             OWL reasoning → inferred JSONL  (requires: pip install owlready2 + Java)
  materialize        compile + reason in sequence
  explain            Show inference result for a specific instance

compile options:
  --target PATH      KB root
  --domain NAME      Specific domain only (default: all)
  --apply            Write .ttl files (default: dry-run)

reason options:
  --target PATH      KB root
  --apply            Write inferred.jsonl (default: dry-run)

materialize options:
  --target PATH      KB root
  --domain NAME      Specific domain only (default: all)
  --apply            Write files (default: dry-run)

explain options:
  --target PATH      KB root
  --instance ID      Instance ID to explain

add options:
  --target PATH               KB root (default: .)
  --cluster NAME              Tbox/Abox cluster name (required)
  --entity LABEL [LABEL...]   Add one or more Tbox entities
  --relation LABEL            Add a Tbox relation
    --source ENTITY_ID        Relation source entity id
    --target-id ENTITY_ID     Relation target entity id
  --instance LABEL            Add an Abox instance
    --type ENTITY_ID          Instance-of Tbox entity id
  --evidence URI [URI...]     evidence:seed:... references (required)
  --status STATUS             draft|accepted|stable|deprecated (default: draft)
  --apply                     Actually write files (default: dry-run)

mece options:
  --target PATH               KB root
  --cluster NAME              Limit to one cluster (default: all)

list options:
  --target PATH               KB root
  --cluster NAME              Limit to one cluster
  --kind entity|relation|instance

project options:
  --target PATH               KB root
  --cluster NAME              Cluster to project
  --apply                     Write MD files (default: dry-run)
EOF
    ;;
  *)
    echo "unknown subcommand: $sub" >&2
    echo "Use 'msm-ontology --help' for usage." >&2
    exit 2
    ;;
esac
