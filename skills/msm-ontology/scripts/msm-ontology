#!/usr/bin/env bash
# msm-ontology — CLI entrypoint for the msm-ontology skill.
# Usage: msm-ontology <command> [options]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# 스킬 venv를 우선 사용 (pyshacl, rdflib 등 격리 설치)
if [[ -x "$SKILL_DIR/.venv/bin/python3" ]]; then
  PY="${PYTHON:-$SKILL_DIR/.venv/bin/python3}"
else
  PY="${PYTHON:-python3}"
fi

sub="${1:-}"
shift || true

case "$sub" in
  add)
    exec "$PY" "$SCRIPT_DIR/add.py" "$@"
    ;;
  mece)
    exec "$PY" "$SCRIPT_DIR/mece.py" "$@"
    ;;
  list)
    exec "$PY" "$SCRIPT_DIR/list.py" "$@"
    ;;
  project)
    exec "$PY" "$SCRIPT_DIR/project_md.py" "$@"
    ;;
  definition)
    exec "$PY" "$SCRIPT_DIR/definition.py" "$@"
    ;;
  shapes-validate)
    exec "$PY" "$SCRIPT_DIR/shapes_validate.py" "$@"
    ;;
  eca-run)
    exec "$PY" "$SCRIPT_DIR/eca_run.py" "$@"
    ;;
  eca-schedule)
    exec "$PY" "$SCRIPT_DIR/eca_schedule.py" "$@"
    ;;
  gen-ddl)
    exec "$PY" "$SCRIPT_DIR/gen_ddl.py" "$@"
    ;;
  compile)
    exec "$PY" "$SCRIPT_DIR/compile.py" "$@"
    ;;
  postprocess)
    exec "$PY" "$SCRIPT_DIR/owl_postprocess.py" "$@"
    ;;
  abox-compile)
    exec "$PY" "$SCRIPT_DIR/abox_compile.py" "$@"
    ;;
  axiom)
    exec "$PY" "$SCRIPT_DIR/axiom.py" "$@"
    ;;
  rbox)
    exec "$PY" "$SCRIPT_DIR/rbox.py" "$@"
    ;;
  reason)
    exec "$PY" "$SCRIPT_DIR/reason.py" "$@"
    ;;
  materialize)
    exec "$PY" "$SCRIPT_DIR/materialize.py" "$@"
    ;;
  explain)
    exec "$PY" "$SCRIPT_DIR/explain.py" "$@"
    ;;
  ""|-h|--help)
    cat <<EOF
msm-ontology — Ontology Manager for MSM v0.13.0

Commands (v0.12.0):
  add                Register entity / relation / instance
  mece               Run MECE violation checks
  list               List registered objects
  project            Regenerate MD projections from JSONL
  definition         Load / query definition YAML
  shapes-validate    SHACL 기반 Tbox 검증 (v0.14.0 — pyshacl)
  eca-run            Execute ECA rules on a table row
  eca-schedule       Schedule ECA rules for a domain
  gen-ddl            Generate SQL DDL from definition

Commands (v0.13.0 — OWL reasoning):
  compile            LinkML YAML → OWL/Turtle (+ owl_postprocess)  (requires: pip install linkml)
  postprocess        owlgen 미지원 OWL 주입 (FunctionalProperty/다국어 label)  (requires: rdflib)
  abox-compile       ABox 인스턴스(YAML) → OWL individual TTL  (requires: rdflib)
  axiom              OWL TBox 공리(HITL) 저작 — 결과 가시화 후 승인 시 병합  (requires: ruamel.yaml)
  reason             OWL reasoning → inferred JSONL (TBox+ABox 병합)  (requires: owlready2 + Java)
  materialize        compile + abox-compile + reason in sequence
  explain            Show inference result for a specific instance

compile options:
  --target PATH      KB root
  --domain NAME      Specific domain only (default: all)
  --out-dir DIR      TTL 출력 디렉토리 (default: <target>/ontology/owl)
  --no-postprocess   owl_postprocess 비활성 (base owlgen 출력 그대로 = v0.13.0)
  --apply            Write .ttl files (default: dry-run)

postprocess options:
  --ttl PATH         직접 모드: 단일 TTL 보강
  --target PATH      repo 모드: KB root (out-dir 내 *.ttl 전체)
  --domain NAME      repo 모드: 특정 도메인 TTL만
  --out-dir DIR      repo 모드: TTL 디렉토리 (default: <target>/ontology/owl)
  --keep-carriers    carrier annotation 트리플 보존 (default: 제거)
  --apply            Write files (default: dry-run)

abox-compile options:
  --target PATH      KB root
  --domain NAME      특정 도메인만 (default: all, ontology/Abox/*.yaml)
  --out-dir DIR      TTL 출력 디렉토리 (default: <target>/ontology/owl)
  --apply            Write {domain}.abox.ttl (default: dry-run)

axiom classification-rule options:
  --target PATH        KB root
  --domain NAME        definition/{domain}.yaml
  --class NAME         분류 대상 클래스
  --is-a NAME          GCI 전제 base 클래스
  --some SLOT:RANGE    존재 제약 (slot some Range), 복수 지정 가능
  --show-inferences    현 ABox 추론 consequence 표시 (Pellet, 느림)
  --apply              HITL 승인 — LinkML 정본에 주석 보존 병합 (default: 미리보기)

reason options:
  --target PATH      KB root
  --out-dir DIR      TTL 입력 디렉토리 (default: <target>/ontology/owl, TBox+ABox 병합)
  --inferred-dir DIR inferred.jsonl 출력 (default: <target>/ontology/Abox/_inferred)
  --apply            Write inferred.jsonl (default: dry-run)

materialize options:
  --target PATH      KB root
  --domain NAME      Specific domain only (default: all)
  --out-dir DIR      TTL 디렉토리 (compile 출력 = reason 입력)
  --inferred-dir DIR inferred.jsonl 출력 디렉토리
  --no-postprocess   compile 단계 owl_postprocess 비활성
  --apply            Write files (default: dry-run)

explain options:
  --target PATH      KB root
  --instance ID      Instance ID to explain

add options:
  --target PATH               KB root (default: .)
  --cluster NAME              Tbox/Abox cluster name (required)
  --entity LABEL [LABEL...]   Add one or more Tbox entities
  --relation LABEL            Add a Tbox relation
    --source ENTITY_ID        Relation source entity id
    --target-id ENTITY_ID     Relation target entity id
  --instance LABEL            Add an Abox instance
    --type ENTITY_ID          Instance-of Tbox entity id
  --evidence URI [URI...]     evidence:seed:... references (required)
  --status STATUS             draft|accepted|stable|deprecated (default: draft)
  --apply                     Actually write files (default: dry-run)

mece options:
  --target PATH               KB root
  --cluster NAME              Limit to one cluster (default: all)

list options:
  --target PATH               KB root
  --cluster NAME              Limit to one cluster
  --kind entity|relation|instance

project options:
  --target PATH               KB root
  --cluster NAME              Cluster to project
  --apply                     Write MD files (default: dry-run)
EOF
    ;;
  *)
    echo "unknown subcommand: $sub" >&2
    echo "Use 'msm-ontology --help' for usage." >&2
    exit 2
    ;;
esac
