#!/usr/bin/env bash
# msm-obsidian-projection CLI entry point (v1.2.0 skeleton)
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  run)  python3 "$SKILL_DIR/run.py" "$@" ;;
  list) python3 "$SKILL_DIR/list.py" "$@" ;;
  *)
    echo "Usage: msm-obsidian-projection <command> [options]"
    echo "Commands: run | list"
    exit 1
    ;;
esac
